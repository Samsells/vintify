# Vintify marketing website (Next.js) — environment variables.
# Copy to .env.local for local dev, or set these in your host (Vercel/Railway).

# Base URL of the Vintify CRM web app (Vintify-CRM). The marketing site's
# "Log in" / "Get started" / "Start free trial" CTAs link to this app's
# existing /login and /signup screens. No trailing slash.
# Defaults to https://app.vintify.co.uk if unset (see lib/site.js).
NEXT_PUBLIC_APP_URL=https://app.vintify.co.uk

# Postgres connection string used by the waitlist API route (app/api/waitlist).
DATABASE_URL=postgresql://user:password@host:5432/vintify
